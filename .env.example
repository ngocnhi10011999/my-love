# Credentials
VITE_ADMIN_PASSWORD=admin123
VITE_GUEST_PASSWORD=guest123

# S3-compatible storage (e.g. MinIO, Cloudflare R2, Backblaze B2, Wasabi)
VITE_S3_ENDPOINT=https://your-s3-endpoint.example.com
VITE_S3_ACCESS_KEY_ID=your_access_key
VITE_S3_SECRET_ACCESS_KEY=your_secret_key
VITE_S3_REGION=us-east-1
VITE_S3_BUCKET=your_gallery_bucket_name

# Telegram Configuration
VITE_TELEGRAM_BOT_TOKEN=your_bot_token
VITE_TELEGRAM_CHAT_ID=your_chat_id
